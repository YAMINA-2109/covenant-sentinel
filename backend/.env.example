# Vultr Serverless Inference (required)
VULTR_API_KEY=your-vultr-serverless-inference-key
VULTR_BASE_URL=https://api.vultrinference.com/v1
VULTR_CHAT_MODEL=Qwen/Qwen3.5-397B-A17B

# VultronRetriever reranker (hybrid retrieval: BM25 recall -> semantic rerank).
# Leave empty to fall back to pure local BM25.
VULTR_RETRIEVER_MODEL=vultr/VultronRetrieverPrime-Qwen3.5-8B
